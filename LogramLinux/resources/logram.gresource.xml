<?xml version="1.0" encoding="UTF-8"?>
<!--
  GtkApplication automatically uses the resource path
  /<application_id-with-dots-as-slashes>/icons as an icon-theme search path.
  For app id com.unitybase.Logram that's /com/unitybase/Logram/icons.

  We list the FS path of each PNG in the body of <file>, but rename it via
  alias= to drop the leading "icons/" so the URL inside the gresource lands
  exactly at /com/unitybase/Logram/icons/hicolor/{N}x{N}/apps/{name}.png —
  i.e. matches the icon-theme lookup.
-->
<gresources>
  <gresource prefix="/com/unitybase/Logram/icons">
    <file alias="hicolor/16x16/apps/com.unitybase.Logram.png">icons/hicolor/16x16/apps/com.unitybase.Logram.png</file>
    <file alias="hicolor/32x32/apps/com.unitybase.Logram.png">icons/hicolor/32x32/apps/com.unitybase.Logram.png</file>
    <file alias="hicolor/64x64/apps/com.unitybase.Logram.png">icons/hicolor/64x64/apps/com.unitybase.Logram.png</file>
    <file alias="hicolor/128x128/apps/com.unitybase.Logram.png">icons/hicolor/128x128/apps/com.unitybase.Logram.png</file>
    <file alias="hicolor/256x256/apps/com.unitybase.Logram.png">icons/hicolor/256x256/apps/com.unitybase.Logram.png</file>
    <file alias="hicolor/512x512/apps/com.unitybase.Logram.png">icons/hicolor/512x512/apps/com.unitybase.Logram.png</file>
  </gresource>
</gresources>